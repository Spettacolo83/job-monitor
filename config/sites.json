    },
    {
      "id": "glassdoor",
      "name": "Glassdoor",
      "type": "html",
      "base_url": "https://www.glassdoor.com/Job/jobs.htm",
      "params": { "sc.keyword": "{keyword}" },
      "keywords": ["iOS developer", "Android developer", "Mobile developer", "Flutter developer", "React Native developer"],
